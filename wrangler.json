{
  "name": "astrofree",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/_worker.js/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "vars": {
    "ENVIRONMENT": "production",
    "API_URL": "https://astrofree.me"
  },
  "env": {
    "uat": {
      "name": "astrofree-uat",
      "vars": {
        "ENVIRONMENT": "uat",
        "API_URL": "https://uat.astrofree.me"
      }
    }
  }
}
