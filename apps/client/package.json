{
  "name": "astrofree-client",
  "description": "Client CMS app — deploys to customer Cloudflare Pages/Worker, reads from R2 (page.json)",
  "private": true,
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro build && wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "check": "astro build && tsc --noEmit && wrangler deploy --dry-run"
  },
  "dependencies": {
    "@astrojs/cloudflare": "12.6.12",
    "@astrojs/mdx": "4.3.12",
    "@astrojs/rss": "4.0.14",
    "@astrojs/sitemap": "3.6.0",
    "astro": "^5.17.3",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "wrangler": "4.56.0"
  }
}
